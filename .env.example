# KATO Environment Configuration
# Copy this file to .env and modify as needed

# API Configuration
KATO_API_PORT=8000
KATO_LOG_LEVEL=INFO

# KATO Processor Manifest (JSON format)
# This contains the processor configuration that would normally be in a genome file
KATO_MANIFEST={"id":"kato-docker","name":"KatoProcessor","indexer_type":"VI","max_sequence_length":0,"persistence":5,"max_predictions":100,"recall_threshold":0.1,"sort":true,"process_predictions":true}

# MongoDB Configuration
MONGO_DB_PORT=27017

# User configuration (will be set automatically)
USER=${USER}

# Database Authentication (Optional)
# Generate credentials with: cd deployment && ./kato-manager.sh setup-auth
# Or set manually below.
#
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_SECURE=false
# REDIS_PASSWORD=
# REDIS_TLS=false
#
# Redis Persistence (Optional)
# Enable RDB+AOF hybrid persistence for data durability across restarts
# REDIS_PERSISTENCE=true
#
# IMPORTANT: To enable Qdrant auth, you must ALSO use docker-compose.auth.yml:
#   docker compose -f docker-compose.yml -f docker-compose.auth.yml up -d
# Setting QDRANT_API_KEY alone is NOT enough — the Qdrant service needs the override.
# QDRANT_API_KEY=
# QDRANT_HTTPS=false

# Individual processor parameters (alternative to KATO_MANIFEST)
# Uncomment and modify these to override the manifest
# KATO_PROCESSOR_ID=my-processor
# KATO_PROCESSOR_NAME=MyProcessor
# KATO_INDEXER_TYPE=VI
# KATO_MAX_SEQUENCE_LENGTH=0
# KATO_PERSISTENCE=5
# KATO_MAX_PREDICTIONS=100
# KATO_RECALL_THRESHOLD=0.1
# KATO_SORT=true
# KATO_PROCESS_PREDICTIONS=true